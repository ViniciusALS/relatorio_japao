POSTGRES_PASSWORD=admin

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:8080

# JWT
ACCESS_TOKEN_LIFETIME_MINUTES=30
REFRESH_TOKEN_LIFETIME_DAYS=1
