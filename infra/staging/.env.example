# infra/staging/.env — STAGING (NUNCA commitar o .env real; apenas este exemplo)
#
# Duas materializacoes deste arquivo:
#  1) PERSISTENTE no host kratos (/opt/jrc/relatorio_japao/infra/staging/.env, chmod 600):
#     usado para subir o `runner` manualmente. Precisa de TODAS as chaves abaixo.
#  2) EFEMERA no workspace do runner: gerada pelo job `deploy` do cd-staging.yml
#     (printf + umask 077) e apagada ao fim. Precisa de IMAGE_TAG, NGINX_PROXY_NETWORK,
#     POSTGRES_DJR_PASSWORD, DJANGO_SECRET_KEY (NAO precisa do RUNNER_ACCESS_TOKEN).

# Tag da imagem a subir (o CD injeta sha-<sha7>; default `latest`).
IMAGE_TAG=latest

# Rede externa do reverse proxy ja existente no host.
NGINX_PROXY_NETWORK=nginx-proxy_default

# Senha do PostgreSQL de staging (consumida pelo Django como DB_PASSWORD tambem).
POSTGRES_DJR_PASSWORD=

# SECRET_KEY do Django (obrigatoria com DEBUG=False).
DJANGO_SECRET_KEY=

# PAT (escopo `repo`) para registrar o runner em ChewieSoft/relatorio_japao.
# Vive APENAS no .env persistente do host — nunca como GitHub secret nem no .env do CD.
RUNNER_ACCESS_TOKEN=
